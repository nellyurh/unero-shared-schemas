{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/ServiceAccountCredentialRotated.schema.json",
  "title": "ServiceAccountCredentialRotated payload",
  "description": "Emitted by identity-service when a service account's client secret is rotated. Never carries the secret or its hash.",
  "type": "object",
  "required": ["service_account_id", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "service_account_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
