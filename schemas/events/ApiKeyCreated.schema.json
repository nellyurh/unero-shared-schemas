{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/ApiKeyCreated.schema.json",
  "title": "ApiKeyCreated payload",
  "description": "Emitted by identity-service when an API key is created. Carries the public prefix and metadata but never the secret or its hash.",
  "type": "object",
  "required": ["api_key_id", "prefix", "name", "owner_type", "owner_id", "scopes", "expires_at", "created_by", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "api_key_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "prefix": { "type": "string", "pattern": "^[a-z0-9]{6,32}$" },
    "name": { "type": "string" },
    "owner_type": { "type": "string", "enum": ["user", "service_account"] },
    "owner_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "scopes": { "type": "array", "items": { "type": "string" } },
    "expires_at": { "anyOf": [ { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }, { "type": "null" } ] },
    "created_by": { "type": "string" },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
