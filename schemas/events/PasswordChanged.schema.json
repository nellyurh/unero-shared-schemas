{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/PasswordChanged.schema.json",
  "title": "PasswordChanged payload",
  "description": "Emitted by identity-service when a user's password hash changes (change or reset). Never carries the hash.",
  "type": "object",
  "required": ["user_id", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "user_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
