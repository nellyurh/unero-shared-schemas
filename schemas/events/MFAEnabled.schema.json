{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/MFAEnabled.schema.json",
  "title": "MFAEnabled payload",
  "description": "Emitted by identity-service when a user activates a second factor. Carries the method; never the secret.",
  "type": "object",
  "required": ["user_id", "method", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "user_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "method": { "type": "string", "enum": ["totp"] },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
