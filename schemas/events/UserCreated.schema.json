{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/UserCreated.schema.json",
  "title": "UserCreated payload",
  "description": "Emitted by identity-service when a user is created (EVENT_CATALOG §UserCreated).",
  "type": "object",
  "required": ["user_id", "tier", "created_at"],
  "additionalProperties": false,
  "properties": {
    "user_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "tier": { "type": "integer", "minimum": 0, "maximum": 3 },
    "email_verified": { "type": "boolean" },
    "phone_verified": { "type": "boolean" },
    "created_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
