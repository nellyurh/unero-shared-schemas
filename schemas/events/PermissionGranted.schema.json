{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/PermissionGranted.schema.json",
  "title": "PermissionGranted payload",
  "description": "Emitted by identity-service when a permission is granted to a role. Reference data, no PII.",
  "type": "object",
  "required": ["role_id", "permission_id", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "role_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "permission_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
