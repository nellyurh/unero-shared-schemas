{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/events/ServiceAccountCreated.schema.json",
  "title": "ServiceAccountCreated payload",
  "description": "Emitted by identity-service when a service account is provisioned. Never carries the secret or its hash.",
  "type": "object",
  "required": ["service_account_id", "name", "scopes", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "service_account_id": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Ulid" },
    "name": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/ServiceName" },
    "scopes": { "type": "array", "items": { "type": "string" } },
    "occurred_at": { "$ref": "https://schemas.unero.com/common.schema.json#/$defs/Timestamp" }
  }
}
