{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unero.com/errors/error-code-registry.schema.json",
  "title": "Error Code Registry",
  "description": "Canonical machine-readable registry of every stable error code. Services import this; new codes are added here first (Rule 5).",
  "type": "object",
  "required": ["version", "codes"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "http_status", "message", "namespace"],
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string", "pattern": "^[A-Z]+_[0-9]{3}$" },
          "namespace": { "type": "string", "pattern": "^[A-Z]+$" },
          "http_status": { "type": "integer", "minimum": 400, "maximum": 599 },
          "message": { "type": "string", "minLength": 1 },
          "deprecated": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
